// Exercises the TextMate grammar without shipping this file in the VSIX.
|============================================================|
// Public identifier documentation
alias Identifier: hex_int /# Hexadecimal identifier;
alias Ratio: hex_float;
alias Status: choice["ready", "waiting"];

schema HighlightSample: {
  id: Identifier,
  label: string,
  count: int,
  ratio: float,
  enabled: boolean,
  tags: array<string>,
  metadata: record<string>,
  status: Status,
};

Identifier id = 0x2A;
Ratio hexadecimal_ratio = 0x1.8;
float decimal_ratio = 1.5;
string missing_label = "not provided";
boolean enabled = true;
string rendered = "id=$(id)";
array<string> tags = ["grammar", "theme"];
record<string> metadata = { editor: "vscode" };
HighlightSample sample = {
  id: id,
  label: rendered,
  count: 42,
  ratio: decimal_ratio,
  enabled: enabled,
  tags: tags,
  metadata: metadata,
  status: "ready",
};
|============================================================|
[output = 'data']
{
  sample: sample,
  hexadecimal_ratio: hexadecimal_ratio,
  missing_label: missing_label,
}
